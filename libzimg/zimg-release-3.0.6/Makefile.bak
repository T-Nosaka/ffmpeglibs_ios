	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(examplemiscdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(examplemiscdir)" || exit $$?; \
	done

uninstall-dist_examplemiscDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(dist_examplemisc_DATA)'; test -n "$(examplemiscdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(examplemiscdir)'; $(am__uninstall_files_from_dir)
install-pkgconfigDATA: $(pkgconfig_DATA)
	@$(NORMAL_INSTALL)
	@list='$(pkgconfig_DATA)'; test -n "$(pkgconfigdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(pkgconfigdir)'"; \
