	$(AM_V_CC)$(LIBTOOL) $(AM_V_lt) --tag=CC $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=compile $(CC) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(AM_CPPFLAGS) $(CPPFLAGS) $(test_libmusl_m_la_CFLAGS) $(CFLAGS) -MT test/extra/musl-libm/libmusl_m_la-__cos.lo -MD -MP -MF test/extra/musl-libm/$(DEPDIR)/libmusl_m_la-__cos.Tpo -c -o test/extra/musl-libm/libmusl_m_la-__cos.lo `test -f 'test/extra/musl-libm/__cos.c' || echo '$(srcdir)/'`test/extra/musl-libm/__cos.c
